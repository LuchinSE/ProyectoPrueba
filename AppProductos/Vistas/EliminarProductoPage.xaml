<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppProductos.Vistas.EliminarProductoPage"
             Title="Eliminar Producto">

    <VerticalStackLayout Spacing="20" Padding="24" VerticalOptions="Center">

        <Label Text="¿Eliminar este producto?"
               FontSize="20" FontAttributes="Bold"
               HorizontalOptions="Center" />

        <Border Stroke="LightGray"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 10"
                Padding="16">
            <VerticalStackLayout Spacing="8">
                <Label Text="{Binding NombreProducto}"
                       FontSize="18" FontAttributes="Bold"
                       HorizontalOptions="Center" />
                <Label Text="{Binding IdProducto, StringFormat='ID: {0}'}"
                       FontSize="14" TextColor="Gray"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Border>

        <Label Text="Esta acción no se puede deshacer."
               TextColor="Gray" FontSize="13"
               HorizontalOptions="Center" />

        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
            <Button Grid.Column="0"
                    Text="Cancelar"
                    BackgroundColor="LightGray"
                    TextColor="Black"
                    CornerRadius="8"
                    HeightRequest="48"
                    Clicked="OnCancelarClicked" />

            <Button Grid.Column="1"
                    Text="Eliminar"
                    Command="{Binding EliminarCommand}"
                    BackgroundColor="#C62828"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="48" />
        </Grid>

        <ActivityIndicator IsRunning="{Binding EstaOcupado}"
                           IsVisible="{Binding EstaOcupado}"
                           HorizontalOptions="Center" />

    </VerticalStackLayout>
</ContentPage>
