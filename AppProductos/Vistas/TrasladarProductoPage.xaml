<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppProductos.Vistas.TrasladarProductoPage"
             Title="Trasladar Producto">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="20">

            <Label Text="Traslado de Producto"
                   FontSize="22" FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,8,0,0" />

            <VerticalStackLayout Spacing="4">
                <Label Text="Nombre del producto" FontSize="13" TextColor="Gray" />
                <Entry Text="{Binding NombreProducto}"
                       Placeholder="Nombre exacto del producto" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="4">
                <Label Text="Sede Origen (ID)" FontSize="13" TextColor="Gray" />
                <Entry Text="{Binding SedeOrigen}"
                       Placeholder="ID sede origen" Keyboard="Numeric" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="4">
                <Label Text="Sede Destino (ID)" FontSize="13" TextColor="Gray" />
                <Entry Text="{Binding SedeDestino}"
                       Placeholder="ID sede destino" Keyboard="Numeric" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="4">
                <Label Text="Cantidad a trasladar" FontSize="13" TextColor="Gray" />
                <Entry Text="{Binding Cantidad}"
                       Placeholder="0" Keyboard="Numeric" />
            </VerticalStackLayout>

            <Button Text="Confirmar traslado"
                    Command="{Binding TrasladarCommand}"
                    BackgroundColor="#4A148C" TextColor="White"
                    CornerRadius="8" HeightRequest="48"
                    Margin="0,8" />

            <ActivityIndicator IsRunning="{Binding EstaOcupado}"
                               IsVisible="{Binding EstaOcupado}"
                               HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
